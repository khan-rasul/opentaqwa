default_platform(:ios)

PROJECT_ROOT = File.expand_path("..", __dir__)
XCODEPROJ    = File.join(PROJECT_ROOT, "ios", "OpenTaqwa.xcodeproj")
XCWORKSPACE  = File.join(PROJECT_ROOT, "ios", "OpenTaqwa.xcworkspace")

# Load .env.fastlane from the mobile/ dir so env vars are always available
env_file = File.join(PROJECT_ROOT, ".env.fastlane")
if File.exist?(env_file)
  File.readlines(env_file).each do |line|
    next if line.strip.empty? || line.start_with?("#")
    k, v = line.strip.split("=", 2)
    ENV[k] ||= v
  end
end

ASC_KEY_FILE = File.join(PROJECT_ROOT, "fastlane", "AuthKey_#{ENV['ASC_KEY_ID']}.p8")

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Authenticate via App Store Connect API key (no 2FA prompts)
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ASC_KEY_FILE,
      duration: 1200,
      in_house: false
    )

    # Generate native iOS project from Expo config
    sh("cd #{PROJECT_ROOT} && npx expo prebuild --platform ios --clean")

    # Increment build number automatically
    increment_build_number(
      xcodeproj: XCODEPROJ
    )

    # Build the archive — -allowProvisioningUpdates lets xcodebuild
    # create/download the distribution profile on the fly via the API key.
    build_app(
      workspace: XCWORKSPACE,
      scheme: "OpenTaqwa",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates DEVELOPMENT_TEAM=#{ENV['TEAM_ID']}",
      api_key: api_key
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: "Latest build from fastlane"
    )
  end
end
