default_platform(:ios)

PROJECT_ROOT = File.expand_path("..", __dir__)
XCODEPROJ    = File.join(PROJECT_ROOT, "ios", "OpenTaqwa.xcodeproj")
XCWORKSPACE  = File.join(PROJECT_ROOT, "ios", "OpenTaqwa.xcworkspace")

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Generate native iOS project from Expo config
    sh("cd #{PROJECT_ROOT} && npx expo prebuild --platform ios --clean")

    # Increment build number automatically
    increment_build_number(
      xcodeproj: XCODEPROJ
    )

    # Build the archive
    build_app(
      workspace: XCWORKSPACE,
      scheme: "OpenTaqwa",
      configuration: "Release",
      export_method: "app-store"
    )

    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      changelog: "Latest build from fastlane"
    )
  end

  desc "Sync code signing certificates (first-time setup)"
  lane :certs do
    match(
      type: "appstore",
      app_identifier: "com.opentaqwa.app",
      readonly: false
    )
  end
end
