{
  "expo": {
    "name": "OpenTaqwā",
    "slug": "opentaqwa",
    "version": "0.0.1",
    "scheme": "opentaqwa",
    "userInterfaceStyle": "dark",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0d0c"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://opentaqwa.app"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow OpenTaqwā to use your location to calculate accurate prayer times.",
          "locationWhenInUsePermission": "Allow OpenTaqwā to use your location to calculate accurate prayer times and Qibla direction."
        }
      ],
      "expo-font",
      "expo-secure-store"
    ],
    "ios": {
      "bundleIdentifier": "com.opentaqwa.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "OpenTaqwā uses your location to calculate accurate prayer times and Qibla direction.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.opentaqwa.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "extra": {
      "router": {
        "origin": "https://opentaqwa.app"
      },
      "eas": {
        "projectId": "d448a33e-cf83-46dc-a7b5-422f06a050e9"
      }
    },
    "owner": "rasulkhan"
  }
}
